PORT=3001

# Origines du front (Vercel), séparées par des virgules
# CORS_ORIGINS=https://ton-projet.vercel.app

# Données persistantes (Render : monter un disque sur /data et définir DATA_DIR=/data)
# DATA_DIR=/data

# ── Authentification (obligatoire en prod) ─────────────────────────────
# Clé de signature des sessions JWT : générer une longue chaîne aléatoire (≥ 32 car.)
# ex. openssl rand -hex 48
JWT_SECRET=change-me-please-change-me-please-change-me

# Admin créé automatiquement au premier démarrage (si aucun admin en base)
ADMIN_EMAIL=admin@exemple.com
ADMIN_PASSWORD=change-me
ADMIN_NAME=Admin

# (facultatif) Clé partagée côté front — uniquement si tu veux une seconde
# barrière en plus de la session. Laisse vide pour désactiver.
# BACKOFFICE_API_KEY=une-longue-chaine-aleatoire

# En production derrière HTTPS : active le cookie "secure"
# NODE_ENV=production
