# Origine du backend uniquement, SANS /api à la fin.
# Ex. https://bo-api-xxxx.onrender.com
# Si vous avez par erreur .../api, ce sera corrigé automatiquement au build.
# Vide en local : le proxy Vite (npm run dev) envoie /api vers le port 3001.
VITE_API_URL=

# Même valeur que BACKOFFICE_API_KEY sur le serveur (optionnel)
VITE_BACKOFFICE_KEY=
